{
  "name": "nano-duoshe",
  "version": "0.1.0-alpha.0",
  "description": "Local-first project memory layer for AI coding agents (Claude Code / Codex / Cursor)",
  "keywords": [
    "mcp",
    "claude-code",
    "codex",
    "cursor",
    "ai-coding",
    "memory",
    "project-memory",
    "duoshe",
    "nano-duoshe"
  ],
  "homepage": "https://github.com/guangdino/nano-duoshe",
  "bugs": "https://github.com/guangdino/nano-duoshe/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guangdino/nano-duoshe.git"
  },
  "license": "MIT",
  "author": "guangdino",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "duoshe": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/index.ts",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "commander": "^12.1.0",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20.17.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
